# Backend base URL the Next.js server proxy (app/api/*) forwards to.
# The browser never talks to the Go backend directly — it always goes through
# the Next.js server layer, which preserves the httpOnly-cookie auth.
#
# Edge deployment (in-restaurant tablets / POS / kitchen):
#   The Next.js app is served FROM the edge node and talks to the local Go node.
#   Works with no internet.
#   NEXT_PUBLIC_API_URL=http://localhost:8080/api
#
# Cloud deployment (admin reviewing remotely):
#   NEXT_PUBLIC_API_URL=https://api.your-cloud-domain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8080/api
